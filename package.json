{
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "name": "quiz-arena-server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node --import ./dist/infrastructure/tracing/tracing.js -r tsconfig-paths/register dist/app/server.js",
    "dev": "tsx watch --import ./src/infrastructure/tracing/tracing.ts ./src/app/server.ts",
    "build": "tsc && tsc-alias",
    "type-check": "tsc --noEmit",
    "test": "pnpm run test:unit",
    "test:watch": "cross-env DOTENV_CONFIG_PATH=.env.test vitest --config vitest.config.ts",
    "test:unit": "cross-env DOTENV_CONFIG_PATH=.env.test vitest run --config vitest.config.ts test/unit",
    "test:api": "cross-env DOTENV_CONFIG_PATH=.env.test vitest run --config vitest.config.ts test/api",
    "test:integration": "cross-env DOTENV_CONFIG_PATH=.env.test vitest run --config vitest.config.ts --maxWorkers=1 test/integration",
    "test:e2e": "cross-env DOTENV_CONFIG_PATH=.env.test RUN_DB_TESTS=true vitest run --config vitest.config.ts --maxWorkers=1 test/e2e",
    "test:integration:prepare": "cross-env DOTENV_CONFIG_PATH=.env.test prisma migrate reset --force",
    "test:integration:db": "cross-env DOTENV_CONFIG_PATH=.env.test RUN_DB_TESTS=true pnpm run test:integration:prepare && cross-env DOTENV_CONFIG_PATH=.env.test RUN_DB_TESTS=true pnpm run test:integration && cross-env DOTENV_CONFIG_PATH=.env.test RUN_DB_TESTS=true pnpm run test:e2e",
    "test:all": "pnpm run test:unit && pnpm run test:api && pnpm run test:integration",
    "test:coverage": "cross-env DOTENV_CONFIG_PATH=.env.test vitest run --config vitest.config.ts --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm run type-check",
    "prepare": "husky",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down",
    "docker:build": "docker compose -f infra/docker/docker-compose.yml build",
    "docker:logs": "docker compose -f infra/docker/docker-compose.yml logs -f",
    "docs:generate": "tsx ./src/docs/generate-openapi.ts && tsx ./src/docs/postprocess-openapi.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "@ts-rest/open-api": "^3.52.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.4",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.7.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@anatine/zod-openapi": "^2.2.8",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@scalar/api-reference": "^1.52.1",
    "@scalar/express-api-reference": "^0.9.7",
    "@socket.io/redis-adapter": "^8.3.0",
    "@t3-oss/env-core": "^0.13.11",
    "@ts-rest/core": "^3.52.1",
    "@ts-rest/express": "^3.52.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.73.5",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "pino-loki": "^3.0.0",
    "prettier": "^3.8.1",
    "prom-client": "^15.1.3",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "zod": "^3.25.76",
    "zod-openapi": "^5.4.6"
  }
}
