PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=verify-full&channel_binding=require
SERVICE_NAME=quiz-arena-api
JWT_SECRET=replace-with-a-strong-random-secret

# Optional: enable Loki log shipping in production
# LOKI_HOST=http://localhost:3100

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_DEBUG=false