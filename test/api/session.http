@apiV1 = http://localhost:4000/api/v1
@sessionBase = {{apiV1}}/sessions

###
# Create session (POST /api/v1/sessions)
# Use existing quiz/user ids from your DB.
POST {{sessionBase}}
Content-Type: application/json

{
  "quizId": "REPLACE_QUIZ_ID",
  "hostId": "REPLACE_HOST_USER_ID"
}

###
# Get session by id (GET /api/v1/sessions/:sessionId)
@sessionId = REPLACE_SESSION_ID
GET {{sessionBase}}/{{sessionId}}

###
# Join session (POST /api/v1/sessions/join)
# joinCode accepts either UUID or full link format.
POST {{sessionBase}}/join
Content-Type: application/json

{
  "joinCode": "REPLACE_JOIN_CODE_OR_LINK",
  "nickname": "player_one"
}

###
# Start session (POST /api/v1/sessions/:sessionId/start)
POST {{sessionBase}}/{{sessionId}}/start
