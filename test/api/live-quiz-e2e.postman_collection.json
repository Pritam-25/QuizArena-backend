    {
      "name": "Quiz - Add Options to Q1",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "[\n  { \"optionText\": \"Paris\", \"isCorrect\": true },\n  { \"optionText\": \"Berlin\", \"isCorrect\": false },\n  { \"optionText\": \"Madrid\", \"isCorrect\": false },\n  { \"optionText\": \"Rome\", \"isCorrect\": false }\n]"
        },
        "url": {
          "raw": "{{baseUrl}}/quizzes/questions/{{q1Id}}/options",
          "host": ["{{baseUrl}}"],
          "path": ["quizzes", "questions", "{{q1Id}}", "options"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Add options status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Add options inserted count is present', function () {",
              "  const body = pm.response.json();",
              "  const count = body && body.data && body.data.count;",
              "  pm.expect(count).to.be.a('number');",
              "});"
            ]
          }
        }
      ]
    },
