  "item": [
    {
      "name": "Auth - Register Owner",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{ownerUsername}}\",\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{ownerPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Register status is 201 or 409', function () {",
              "  pm.expect([201, 409]).to.include(pm.response.code);",
              "});",
              "",
              "pm.test('Register response shape is valid', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.have.property('success');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth - Login Owner",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{ownerPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Save owner user id', function () {",
              "  const body = pm.response.json();",
              "  const ownerUserId = body && body.data && body.data.user && body.data.user.id;",
              "  pm.expect(ownerUserId).to.be.a('string').and.not.empty;",
              "  pm.environment.set('ownerUserId', ownerUserId);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Quiz - Create Quiz",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"{{quizTitle}}\",\n  \"description\": \"{{quizDescription}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/quizzes",
          "host": ["{{baseUrl}}"],
          "path": ["quizzes"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Create quiz status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Save quiz id', function () {",
              "  const body = pm.response.json();",
              "  const quizId = body && body.data && body.data.id;",
              "  pm.expect(quizId).to.be.a('string').and.not.empty;",
              "  pm.environment.set('quizId', quizId);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Quiz - Add Question 1",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"questionText\": \"{{question1Text}}\",\n  \"type\": \"MCQ\",\n  \"timeLimit\": 30,\n  \"points\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/quizzes/{{quizId}}/questions",
          "host": ["{{baseUrl}}"],
          "path": ["quizzes", "{{quizId}}", "questions"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Add question 1 status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Save question 1 id and order', function () {",
              "  const body = pm.response.json();",
              "  const id = body && body.data && body.data.id;",
              "  const order = body && body.data && body.data.order;",
              "  pm.expect(id).to.be.a('string').and.not.empty;",
              "  pm.expect(order).to.be.a('string').and.not.empty;",
              "  pm.environment.set('q1Id', id);",
              "  pm.environment.set('q1Order', order);",
              "});"
            ]
          }
        }
      ]
    },
